NODE_ENV="development"

WEB_PORT="3000"
API_PORT="3001"
ACARS_PORT="3002"

DATABASE_URL="postgresql://postgres:postgres@localhost:5432/va_platform?schema=public"

# Développement local :
CORS_ORIGIN="http://localhost:3000,http://127.0.0.1:3000"
# Production recommandée :
# CORS_ORIGIN="https://virtual-easyjet-web.vercel.app,https://virtualeasyjet.example.com"
WEB_API_BASE_URL="http://localhost:3001/api"
NEXT_PUBLIC_API_URL="http://localhost:3001"
NEXT_PUBLIC_API_BASE_URL="http://localhost:3001/api"
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_ACARS_BASE_URL="http://localhost:3002/acars"
NEXT_PUBLIC_WS_BASE_URL="ws://localhost:3001"
DESKTOP_API_BASE_URL="http://localhost:3001/api"
DESKTOP_ACARS_BASE_URL="http://localhost:3002/acars"
DESKTOP_BACKEND_MODE="mock"
DESKTOP_CLIENT_VERSION="0.1.0-desktop-mvp"
DESKTOP_SIMULATOR_PROVIDER="MSFS_MOCK"
# Production desktop target example:
# DESKTOP_API_BASE_URL="https://api.virtual-easyjet.fr/api"
# DESKTOP_ACARS_BASE_URL="https://api.virtual-easyjet.fr/acars"
# DESKTOP_BACKEND_MODE="live"
# DESKTOP_TELEMETRY_MODE="simconnect"
# DESKTOP_SIMULATOR_PROVIDER="MSFS2024_SIMCONNECT"
NEXT_PUBLIC_ACARS_CURRENT_VERSION="0.1.0"
ACARS_DOWNLOAD_URL="https://downloads.virtualeasyjet.example/Virtual-Easyjet-ACARS-Setup-0.1.0-x64.exe"
NEXT_PUBLIC_ACARS_DOWNLOAD_URL="https://downloads.virtualeasyjet.example/Virtual-Easyjet-ACARS-Setup-0.1.0-x64.exe"

JWT_ACCESS_SECRET="change-me-access"
JWT_REFRESH_SECRET="change-me-refresh"
JWT_ACCESS_TTL="15m"
JWT_REFRESH_TTL="30d"
BLOB_READ_WRITE_TOKEN=""

S3_ENDPOINT="http://localhost:9000"
S3_REGION="eu-west-1"
S3_ACCESS_KEY="change-me"
S3_SECRET_KEY="change-me"
S3_BUCKET="va-platform"

ACARS_RESUME_TIMEOUT_MINUTES="20"
ACARS_OVERSPEED_GRACE_SECONDS="15"
ACARS_HARD_LANDING_THRESHOLD_FPM="-500"

# Production seed (clean by default)
SEED_ADMIN_EMAIL="admin@virtual-easyjet.local"
SEED_ADMIN_USERNAME="virtualeasyjet-admin"
SEED_ADMIN_PASSWORD="ChangeMe-Admin123!"
SEED_ADMIN_FIRST_NAME="Virtual"
SEED_ADMIN_LAST_NAME="Admin"
SEED_ADMIN_COUNTRY_CODE="FR"

# Optional real pilot bootstrap. Leave empty to keep public stats at 0.
SEED_PILOT_EMAIL=""
SEED_PILOT_USERNAME=""
SEED_PILOT_PASSWORD=""
SEED_PILOT_FIRST_NAME=""
SEED_PILOT_LAST_NAME=""
SEED_PILOT_COUNTRY_CODE="FR"
SEED_PILOT_NUMBER=""
SEED_PILOT_CALLSIGN=""
SEED_PILOT_SIMBRIEF_ID=""
