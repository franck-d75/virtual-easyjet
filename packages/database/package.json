{
  "name": "@va/database",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "Schema Prisma et outillage base de donnees.",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "prisma",
    "prisma.config.ts"
  ],
  "scripts": {
    "build": "pnpm run prisma:generate && tsc -p tsconfig.json",
    "prisma:generate": "prisma generate --schema ./prisma/schema.prisma",
    "prisma:migrate": "prisma migrate dev",
    "prisma:seed": "tsx prisma/seed.ts",
    "prisma:seed:demo": "tsx prisma/seed.demo.ts",
    "lint": "echo \"No lint configured for @va/database\"",
    "test": "echo \"No tests configured for @va/database\""
  },
  "dependencies": {
    "@prisma/client": "6.18.0",
    "bcryptjs": "3.0.3"
  },
  "devDependencies": {
    "@types/node": "25.6.0",
    "prisma": "6.18.0",
    "tsx": "4.21.0",
    "typescript": "6.0.3"
  }
}



